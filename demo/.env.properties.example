# Copy this file to .env.properties on each device and fill your own values.
# This file is read automatically by Spring Boot via spring.config.import.

# Neon settings
NEON_JDBC_URL=jdbc:postgresql://<your-neon-host>/neondb?sslmode=require&channelBinding=require
NEON_DB_USER=<your-neon-user>
NEON_DB_PASSWORD=<your-neon-password>

# Mail settings (use app password for Gmail)
APP_MAIL_HOST=smtp.gmail.com
APP_MAIL_PORT=587
APP_MAIL_USERNAME=<your-email@example.com>
APP_MAIL_PASSWORD=<your-app-password>

# Base URL used to generate verification links
APP_VERIFICATION_BASE_URL=http://localhost:8080
